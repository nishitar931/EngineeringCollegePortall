ats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="sqlite_sequence" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="39"/><column index="2" value="29"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">INSERT INTO colleges
(name, branch, address, fees, cutoff_1g, cutoff_2a, cutoff_scr, exam_type, round)
SELECT &quot;college name&quot;, branch, Address, Fees, &quot;1g&quot;, &quot;2a&quot;, scr, 'KCET', 1
FROM &quot;1 (1)&quot;;
</sql><sql name="SQL 2*">INSERT INTO colleges
(name, branch, address, fees, cutoff_1g, cutoff_2a, cutoff_scr, exam_type, round)
SELECT &quot;College Name&quot;, Branch, Address, Fees, &quot;1G Cutoff&quot;, &quot;2A Cutoff&quot;, &quot;SCR Cutoff&quot;, 'KCET', 2
FROM &quot;11 (1)&quot;;</sql><sql name="SQL 3*">SELECT COUNT(*) FROM colleges;
</sql><sql name="SQL 4*">SELECT * FROM colleges LIMIT 10;
</sql><sql name="SQL 5*">SELECT * 
FROM colleges
WHERE branch = 'Computer Science';
</sql><current_tab id="4"/></tab_sql></sqlb_project>
